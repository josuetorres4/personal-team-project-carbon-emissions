# LLM Configuration
# Set ONE of the following API keys (or leave both blank to use mock LLM):
OPENAI_API_KEY=your-key-here
GROQ_API_KEY=               # optional — get free key at console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=auto           # "auto" | "openai" | "groq" | "mock"
LLM_MODEL=gpt-4o-mini

# Pipeline Configuration
SIM_DAYS=30
SEED=42
MAX_NEGOTIATION_ROUNDS=4
MAX_LLM_RATIONALES=50        # max individual LLM calls for recommendation rationales
MAX_LLM_TICKETS=50           # max individual LLM calls for ticket generation
MAX_LLM_RISK_ASSESSMENTS=50  # max individual LLM calls for governance risk assessments

# Carbon Market
WEEKLY_CARBON_BUDGET_KG=500
CARBON_PRICE_PER_TON=75
MAX_REPLAN_CYCLES=2
MIN_CARBON_SAVING_PCT=5

# Real Carbon Intensity Data (recommended)
USE_REAL_CARBON_DATA=true
CARBON_DATA_CACHE_HOURS=6
EIA_API_KEY=                 # US regions — get free key at eia.gov/opendata
ENTSOE_API_TOKEN=            # EU regions — free registration at transparency.entsoe.eu

# Real Workload Data (Azure VM Traces 2019)
USE_REAL_WORKLOAD_DATA=false
WORKLOAD_DATA_PATH=data/azure_traces/vmtable.csv
# Download: wget https://azurepublicdatasettraces.blob.core.windows.net/azurepublicdatasetv2/trace_data/vmtable/vmtable.csv.gz
