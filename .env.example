# ── LLM Configuration ─────────────────────────────────────────────────
# Multi-agent + small single-model use Groq (free tier at console.groq.com)
GROQ_API_KEY=                     # required for multi-agent + single-model (small)
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=auto                 # "auto" | "openai" | "groq" | "mock"
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=                   # optional alternative to Groq

# Frontier model — used by run_comparison.py for the "single big model" baseline
ANTHROPIC_API_KEY=                # required for run_comparison.py --frontier
FRONTIER_MODEL=claude-sonnet-4-6
FRONTIER_PROVIDER=anthropic       # "anthropic" | "openai"

# ── Real-Data-Only Mode (the new default) ─────────────────────────────
# When true, the orchestrator aborts at startup if any required real source
# is missing. Set to false only for offline development; reported numbers
# are not defensible in legacy mode.
REAL_DATA_ONLY=true

# ── Real Carbon Intensity Data ────────────────────────────────────────
USE_REAL_CARBON_DATA=true
CARBON_DATA_CACHE_HOURS=6
ELECTRICITYMAPS_API_TOKEN=        # PRIMARY — covers all 5 regions; register at api-portal.electricitymaps.com
EIA_API_KEY=                      # SECONDARY (US fallback) — free at eia.gov/opendata
ENTSOE_API_TOKEN=                 # LEGACY (EU fallback) — free at transparency.entsoe.eu

# ── Real Workload Data (Azure VM Traces 2019) ─────────────────────────
USE_REAL_WORKLOAD_DATA=true
WORKLOAD_DATA_PATH=data/azure_traces/vmtable.csv
# Download (~780MB):
#   wget https://azurepublicdatasettraces.blob.core.windows.net/azurepublicdatasetv2/trace_data/vmtable/vmtable.csv.gz
#   gunzip vmtable.csv.gz && mkdir -p data/azure_traces && mv vmtable.csv data/azure_traces/

# ── Pipeline Configuration ────────────────────────────────────────────
SIM_DAYS=30
SEED=42
MAX_NEGOTIATION_ROUNDS=4
MAX_LLM_RATIONALES=10             # cap LLM rationale calls per pipeline
MAX_LLM_TICKETS=10                # cap LLM ticket bodies per pipeline
MAX_LLM_RISK_ASSESSMENTS=10       # cap LLM risk assessments per pipeline
MAX_TOTAL_LLM_TOKENS=100000

# ── Carbon Market ─────────────────────────────────────────────────────
WEEKLY_CARBON_BUDGET_KG=500
CARBON_PRICE_PER_TON=75
MAX_REPLAN_CYCLES=2
MIN_CARBON_SAVING_PCT=5

# ── Energy estimation (architecture comparison) ───────────────────────
# Source: Patterson et al. 2021 / Luccioni et al. 2023 — H100/A100 inference
ENERGY_WH_PER_1K_PROMPT_TOKENS=0.05
ENERGY_WH_PER_1K_COMPLETION_TOKENS=0.30
LLM_GRID_INTENSITY_GCO2_KWH=386   # US grid average (EPA eGRID 2023)
